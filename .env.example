# DB 설정
DB_USERNAME=sip_user
DB_PASSWORD=강한비밀번호로변경하세요

# JWT (openssl rand -base64 64 로 생성)
JWT_SECRET=여기에_최소_64자_이상의_랜덤_시크릿키를_입력하세요

# 카카오 OAuth2
KAKAO_CLIENT_ID=카카오_REST_API_키
KAKAO_CLIENT_SECRET=카카오_Client_Secret

# 프론트엔드 URL (Vercel 배포 후 변경)
FRONTEND_URL=https://your-app.vercel.app

# CORS 허용 도메인 (Vercel 배포 후 변경)
APP_ALLOWED_ORIGINS=https://your-app.vercel.app
